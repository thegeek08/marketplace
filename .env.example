# ─────────────────────────────────────────────────────────────
# Copie ce fichier en .env et remplis les valeurs réelles.
# Ne commite JAMAIS le fichier .env dans git.
# ─────────────────────────────────────────────────────────────

# Génère une clé secrète forte :
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=remplace-par-une-vraie-cle-secrete

# True en développement local, False en production
DEBUG=False

# Domaine Railway (ex: monsite.up.railway.app) + localhost pour les tests locaux
ALLOWED_HOSTS=monsite.up.railway.app,localhost,127.0.0.1

# Même valeur que ALLOWED_HOSTS mais avec le protocole https://
CSRF_TRUSTED_ORIGINS=https://monsite.up.railway.app,http://localhost:8000

# Railway injecte automatiquement DATABASE_URL quand tu ajoutes un plugin PostgreSQL.
# Format : postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Cloudinary — stockage persistant des images (produits, avatars)
# Crée un compte gratuit sur https://cloudinary.com puis copie les valeurs depuis
# Dashboard → Product Environment Credentials
CLOUDINARY_CLOUD_NAME=ton-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=ton-api-secret

# Compte Gmail pour l'envoi d'emails (signalements, reset password…)
EMAIL_HOST_USER=babacardabo109@gmail.com
EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
DEFAULT_FROM_EMAIL=Marketplace <babacardabo109@gmail.com>

# Email de l'administrateur qui reçoit les signalements d'utilisateurs
ADMIN_EMAIL=ton-email-admin@gmail.com
